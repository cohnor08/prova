rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // School-Safe: a 1-to-1 chatId is the two participants' UIDs sorted and
    // joined with '_' (see makeChatId in src/lib/chat.js; Firebase UIDs never
    // contain '_'). A direct message thread is only permitted between a teacher
    // and their own student — one participant must have the other set as their
    // teacherUid. This blocks student↔student messaging at the database, not
    // just in the app UI. (Teacher↔personal counts too — personal users can
    // link a teacher via teacherUid.)
    function isTeacherStudentChat(chatId) {
      let parts = chatId.split('_');
      return parts.size() == 2
        && (
          get(/databases/$(database)/documents/users/$(parts[0])).data.get('teacherUid', '') == parts[1] ||
          get(/databases/$(database)/documents/users/$(parts[1])).data.get('teacherUid', '') == parts[0] ||
          parts[1] in get(/databases/$(database)/documents/users/$(parts[0])).data.get('teacherUids', []) ||
          parts[0] in get(/databases/$(database)/documents/users/$(parts[1])).data.get('teacherUids', [])
        );
    }

    // Founders' admin panel (prova-583c9.web.app/admin). Admin access is
    // pinned to the founders' own auth UIDs — server-side enforcement, not
    // just a login screen. Add Cohnor's UID when known.
    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        '0ZC25xoENxWUcyLYAmDjSAiuCEQ2'   // Ethan (ethanlam2309@gmail.com)
      ];
    }

    // User profiles ─────────────────────────────────────────────────────────
    // Any signed-in user can read another user's profile (required for the
    // teacher search-by-email feature). Only the owner can write.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      // Any of the student's linked teachers (student.teacherUid == teacher, OR
      // teacher in student.teacherUids) may update ONLY their assignedTasks — so
      // a teacher can assign tasks to the student's own record. Students connect
      // to multiple teachers via their own teacherUids (owner write).
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedTasks'])
        && (resource.data.teacherUid == request.auth.uid
            || request.auth.uid in resource.data.get('teacherUids', []));
      // A linked teacher may also unlink themselves from a student (edits only
      // the teacherUid / teacherUids link fields).
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherUid', 'teacherUids'])
        && (resource.data.teacherUid == request.auth.uid
            || request.auth.uid in resource.data.get('teacherUids', []));

      // In-app notification inbox (the bell on Today): any signed-in user can
      // DROP a notification here (gig invites, teacher task alerts) but only
      // the owner can read, mark read, or delete them.
      match /inbox/{noteId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // Session history — written by the app when a session is rated,
    // read by the app for Progress charts. Owner-only access.
    match /sessionHistory/{userId}/{document=**} {
      // Owner reads + writes their own history; a linked teacher may read it
      // (to show the student's practice heatmap on the teacher dashboard).
      allow read: if isAdmin() || (request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(userId)).data.get('teacherUid', '') == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.get('teacherUids', [])
      ));
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Direct messages between any two users ─────────────────────────────────
    // chatId = sorted(uid1, uid2).join('_')
    // Reading / editing / deleting messages: either participant (unchanged —
    // keeps history readable and delete-for-everyone working, and lets a
    // now-unlinked pair still see their old thread).
    match /chats/{chatId}/messages/{messageId} {
      allow read, update, delete: if request.auth != null && (
        chatId.matches(request.auth.uid + '_.*') ||
        chatId.matches('.*_' + request.auth.uid)
      );
      // Sending a new message: participant AND a teacher↔student pair. This is
      // the School-Safe enforcement — students can't message each other even by
      // bypassing the app.
      allow create: if request.auth != null && (
        chatId.matches(request.auth.uid + '_.*') ||
        chatId.matches('.*_' + request.auth.uid)
      ) && isTeacherStudentChat(chatId);
    }

    // Chat-level state (read receipts) — a `lastRead` map keyed by uid.
    // Either participant may read both sides and write their own marker.
    match /chats/{chatId} {
      allow read, write: if request.auth != null && (
        chatId.matches(request.auth.uid + '_.*') ||
        chatId.matches('.*_' + request.auth.uid)
      );
    }

    // Conversation metadata — used to list a user's chats ───────────────────
    // Each participant can read their own list; either participant can write
    // (so sending a message updates both users' conversation lists).
    match /userChats/{uid}/conversations/{chatId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        chatId.matches(request.auth.uid + '_.*') ||
        chatId.matches('.*_' + request.auth.uid)
      );
    }

    // Live gigs (audience song requests) ─────────────────────────────────────
    // The gig doc is public-read so the audience web page can load the setlist
    // without signing in; only the owner can create/change/end it. Anyone may
    // submit a request (anonymous audience); only the owner reads them back.
    match /liveGigs/{gigId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;

      match /requests/{reqId} {
        allow create: if request.resource.data.keys().hasOnly(['title', 'artist', 'ts'])
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 120;
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/liveGigs/$(gigId)).data.ownerUid == request.auth.uid;
      }
    }

    // Backend-only collections ───────────────────────────────────────────────
    // These are written exclusively by Cloud Functions via the Firebase Admin
    // SDK, which bypasses security rules entirely. Block all direct client
    // reads and writes so the app can never accidentally hit these.
    match /rateLimits/{document=**} {
      allow read, write: if isAdmin();   // admin panel: inspect + reset limits
    }
    match /usageLogs/{document=**} {
      allow read, write: if false;
    }
    match /adminStats/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /adminAlerts/{document=**} {
      allow read, write: if isAdmin();   // admin panel: view + dismiss alerts
    }

    // Cached song-learning plans — any signed-in user can READ (so cache hits are
    // shared), but only the generateSongPlan Cloud Function (admin SDK) may write.
    match /songPlans/{key} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Class group chats (announcements) ──────────────────────────────────────
    // One shared thread per teacher's class. memberUids = [teacherUid, ...uids].
    // It is an announcements channel: only the owning teacher may post; members
    // may only react. Members find their groups with a
    // `where('memberUids','array-contains', uid)` query, which the read rule
    // below satisfies per returned doc.
    match /groupChats/{groupId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.memberUids;
      // Only REAL teacher accounts may create groups — otherwise any user could
      // set themselves as teacherUid, add arbitrary victim UIDs, and broadcast.
      allow create: if request.auth != null
        && request.resource.data.teacherUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      // Only the owning teacher manages the group (name, roster, delete) and
      // bumps the last-message preview when they post.
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.teacherUid;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groupChats/$(groupId)).data.memberUids;
        // Only the teacher posts (and may delete their own posts).
        allow create, delete: if request.auth != null
          && get(/databases/$(database)/documents/groupChats/$(groupId)).data.teacherUid == request.auth.uid;
        // Any member may react: they can change ONLY the reactions field, and it
        // must stay a map.
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groupChats/$(groupId)).data.memberUids
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && request.resource.data.reactions is map;
      }
    }

    // Admin panel organisations (grouping teachers under schools/studios).
    // Admin-only for now; the in-app school hierarchy can adopt this later.
    match /organisations/{orgId} {
      allow read, write: if isAdmin();
    }

    // Remote app switches (maintenance kill-switch, paywall toggle…). World-
    // readable — maintenance must be checkable before login — and written only
    // from the Firebase console / admin SDK, never by clients. NOTE: without
    // this block the deny-all below silently broke the maintenance switch.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
