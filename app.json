{
  "expo": {
    "name": "prova",
    "slug": "prova",
    "version": "1.0.0",
    "scheme": "prova",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ethanlam.prova",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Prova uses the microphone to tune your instrument and record video messages.",
        "NSPhotoLibraryUsageDescription": "Prova lets you attach photos and videos to your chats.",
        "NSCameraUsageDescription": "Prova uses the camera to take photos and record videos for your chats."
      }
    },
    "android": {
      "package": "com.ethanlam.prova",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Prova lets you attach photos and videos to your chats.",
          "cameraPermission": "Prova uses the camera to take photos and record videos for your chats."
        }
      ],
      "expo-notifications",
      "expo-video",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Prova saves practice videos you record to your camera roll so you keep a copy."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "11cd202c-966d-4820-87c9-3d7a984a7026"
      }
    },
    "owner": "ethanlam2309"
  }
}
