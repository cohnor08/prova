{
  "expo": {
    "name": "prova",
    "slug": "prova",
    "version": "1.0.0",
    "scheme": "prova",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Prova uses the microphone to tune your instrument.",
        "NSPhotoLibraryUsageDescription": "Prova lets you attach photos and videos to your chats."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Prova lets you attach photos and videos to your chats."
        }
      ]
    ]
  }
}
