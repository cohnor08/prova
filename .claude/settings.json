{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "permissions": {
    "ask": [
      "Bash(eas update*)",
      "Bash(eas submit*)",
      "Bash(npx eas update*)",
      "Bash(npx eas submit*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/ethanlam/prova && git pull 2>/dev/null || true",
            "statusMessage": "Pulling latest code from GitHub..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/ethanlam/prova && git add . && git diff --cached --quiet || git commit -m 'auto-save' && git push 2>/dev/null || true",
            "statusMessage": "Pushing changes to GitHub..."
          }
        ]
      }
    ]
  }
}
